# Copy to .env on deployment hosts. Settings loads this file automatically.

HUMPBACK_API_HOST=0.0.0.0
HUMPBACK_API_PORT=8000
HUMPBACK_ALLOWED_HOSTS=*.trycloudflare.com,localhost,127.0.0.1

HUMPBACK_STORAGE_ROOT=/workspace/data
# Optional overrides; if unset, these default under HUMPBACK_STORAGE_ROOT.
# HUMPBACK_POSITIVE_SAMPLE_PATH=/workspace/data/labeled/positives
# HUMPBACK_NEGATIVE_SAMPLE_PATH=/workspace/data/labeled/negatives
# HUMPBACK_S3_CACHE_PATH=/workspace/data/s3-orcasound-cache

TF_EXTRA=tf-linux-cpu
